rule Malicious_Skill_Exfiltration {
  meta:
    description = "Detects skills that exfiltrate API keys"
    author = "Capsule Security Team"
    date = "2026-03-18"
    severity = "critical"
  
  strings:
    // OpenAI-style API keys
    $api_key_openai = /sk-[a-zA-Z0-9]{48,}/
    
    // Generic API key patterns
    $api_key_generic = /api[_-]?key[_-]?["']?\s*[:=]\s*["'][a-zA-Z0-9_-]{20,}/ nocase
    
    // Bearer tokens
    $bearer_token = /bearer\s+[a-zA-Z0-9_-]{20,}/ nocase
    
    // Exfiltration keywords
    $exfil_keyword1 = "exfiltrate" nocase
    $exfil_keyword2 = "steal" nocase
    $exfil_keyword3 = "collect" nocase
    
    // Obfuscated function names
    $obfuscated1 = /_0x[a-f0-9]{4}/
    $obfuscated2 = /var\s+_[a-z0-9]+\s*=/
    
    // External fetch/network calls
    $external_fetch = /fetch\s*\(\s*['"]https?:\/\//
    $external_xhr = /XMLHttpRequest/
    
    // Suspicious file paths
    $sensitive_path1 = ".aws/credentials" nocase
    $sensitive_path2 = ".ssh/id_rsa" nocase
    $sensitive_path3 = ".env" nocase
    
    // Base64 encoding (obfuscation indicator)
    $base64_encode = /Buffer\.from\([^)]+,\s*['"]base64['"]\)/
    $btoa_call = /btoa\s*\(/
    
  condition:
    any of ($api_key_openai, $api_key_generic, $bearer_token) or
    any of ($exfil_keyword1, $exfil_keyword2, $exfil_keyword3) or
    2 of ($obfuscated1, $obfuscated2, $base64_encode, $btoa_call) or
    any of ($external_fetch, $external_xhr) and any of ($sensitive_path1, $sensitive_path2, $sensitive_path3)
}

rule Malicious_Skill_Network {
  meta:
    description = "Detects skills with undeclared network access"
    severity = "high"
  
  strings:
    // Network API calls
    $fetch = "fetch("
    $axios = "axios"
    $http = "http.request"
    $https = "https.request"
    $xhr = "XMLHttpRequest"
    $websocket = "WebSocket"
    
    // URL patterns
    $url_pattern = /['"]https?:\/\/[a-zA-Z0-9.-]+/
    
  condition:
    any of ($fetch, $axios, $http, $https, $xhr, $websocket) and
    $url_pattern
}

rule Malicious_Skill_FileAccess {
  meta:
    description = "Detects skills accessing sensitive files"
    severity = "high"
  
  strings:
    // Sensitive file paths
    $aws_creds = ".aws/credentials" nocase
    $gcp_creds = ".gcloud" nocase
    $azure_creds = ".azure" nocase
    $ssh_key = ".ssh/id_rsa" nocase
    $env_file = ".env" nocase
    $openclaw_config = ".openclaw/config" nocase
    
    // Home directory access
    $home_access = /~\/\.|process\.env\.HOME/
    
  condition:
    any of ($aws_creds, $gcp_creds, $azure_creds, $ssh_key, $env_file, $openclaw_config)
}